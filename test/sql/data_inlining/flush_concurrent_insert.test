# name: test/sql/data_inlining/flush_concurrent_insert.test
# description: flush_inlined_data should not duplicate rows when INSERT runs concurrently
# group: [data_inlining]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS lake (DATA_PATH '${DATA_PATH}/flush_concurrent/', DATA_INLINING_ROW_LIMIT 10000)

statement ok
CREATE TABLE lake.events (id INT, val VARCHAR);

# insert some initial data
statement ok
INSERT INTO lake.events SELECT i, 'value_' || i FROM range(20) tbl(i);

# flush should preserve exact row count
statement ok
CALL ducklake_flush_inlined_data('lake');

query I
SELECT count(*) FROM lake.events
----
20

# insert more data and flush again - no duplication
statement ok
INSERT INTO lake.events SELECT i + 20, 'value_' || (i + 20) FROM range(20) tbl(i);

statement ok
CALL ducklake_flush_inlined_data('lake');

query I
SELECT count(*) FROM lake.events
----
40

# verify data integrity
query I
SELECT count(DISTINCT id) FROM lake.events
----
40
