# name: test/sql/schema_cache/schema_cache_eviction.test
# description: Test that schema cache does not grow unbounded with many schema changes
# group: [schema_cache]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/schema_cache_eviction')

statement ok
CREATE TABLE ducklake.base (id INT)

statement ok
INSERT INTO ducklake.base VALUES (1)

# Each CREATE/DROP generates a new schema version that gets cached
# With 100 iterations, the cache should evict old entries (MAX_CACHED_SCHEMAS=64)
loop i 0 100

statement ok
CREATE TABLE ducklake.temp_${i} (id INT)

statement ok
DROP TABLE ducklake.temp_${i}

endloop

# The table should still be queryable after many schema changes
query I
SELECT count(*) FROM ducklake.base
----
1
